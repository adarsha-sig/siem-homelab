# ── LLM backends ──────────────────────────────────────────────────────────────
# Select active backend: groq (default) | claude | ollama
LLM_BACKEND=groq

# Groq cloud API — https://console.groq.com → API Keys
GROQ_API_KEY=gsk_...

# Anthropic API — https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Shuffle SOAR ──────────────────────────────────────────────────────────────
# First-run admin account — used only when the shuffle-backend container
# initialises for the first time. Change the password via the Shuffle UI after.
SHUFFLE_DEFAULT_USERNAME=admin
SHUFFLE_DEFAULT_PASSWORD=changeme_strong_password

# Encrypt stored credentials. Set once and NEVER change.
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
SHUFFLE_ENCRYPTION_MODIFIER=changeme_random_hex_string

# Webhook URL for the Shuffle HTTP trigger that receives ML alert payloads.
#
# How to get this URL:
#   1. Open http://localhost:3001 and log in to Shuffle
#   2. Create or open a workflow
#   3. Add a "Webhook" trigger node (from the Triggers panel on the left)
#   4. Click the trigger node → copy the "Webhook URI" shown in the sidebar
#   5. Paste it here using the container hostname (not localhost) so the
#      notifier can reach it from inside the jupyter container:
SHUFFLE_WEBHOOK_URL=http://shuffle-backend:5001/api/v1/hooks/webhook_REPLACE_ME

# ── CALDERA adversary emulation ───────────────────────────────────────────────
# API key injected into conf/local.yml at container startup.
# Generate: python3 -c "import secrets; print(secrets.token_hex(20))"
# Must match the KEY header used by caldera_monitor.py.
CALDERA_API_KEY=changeme_caldera_api_key

# CALDERA server URL as seen from caldera_monitor.py:
#   Running on the host:              http://localhost:8889  (host port; 8888 taken by Jupyter)
#   Running inside jupyter container: http://caldera:8888   (container-internal port on soc_net)
CALDERA_URL=http://localhost:8889

# Optional: override default UI passwords (red team / blue team logins)
# CALDERA_RED_PASSWORD=redpassword
# CALDERA_BLUE_PASSWORD=bluepassword

# Required internally by CALDERA — set stable values so encrypted artefacts
# survive container restarts. Generate: python3 -c "import secrets; print(secrets.token_hex(16))"
CALDERA_CRYPT_SALT=changeme_crypt_salt
CALDERA_ENCRYPTION_KEY=changeme_encryption_key

# Sandcat agent callback URL — set to your Mac's LAN IP + host port 8889
# so agents deployed to the Windows VM know where to phone home.
# Example: CALDERA_CONTACT_URL=http://192.168.1.100:8889
CALDERA_CONTACT_URL=http://0.0.0.0:8888

# ── Docker Compose project name ───────────────────────────────────────────────
# Controls the Docker network prefix. The Wazuh compose attaches to
# ${COMPOSE_PROJECT_NAME}_soc_net. Verify with: docker network ls | grep soc
COMPOSE_PROJECT_NAME=homelabsiem

# ── Service URLs (defaults match docker-compose.yml) ─────────────────────────
ELASTIC_URL=http://localhost:9200
OLLAMA_URL=http://localhost:11434
MLFLOW_TRACKING_URI=http://localhost:5000
